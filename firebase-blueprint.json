{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project item",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "image": { "type": "string" },
        "span": { "type": "string", "enum": ["wide", "portrait", "normal"] },
        "isFeatured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "order": { "type": "number" },
        "description": { "type": "string" },
        "client": { "type": "string" },
        "year": { "type": "string" },
        "role": { "type": "string" },
        "duration": { "type": "string" },
        "liveUrl": { "type": "string" }
      },
      "required": ["title", "image", "span", "isFeatured"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Privileged users",
      "type": "object",
      "properties": {
        "email": { "type": "string" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of all portfolio projects"
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "Collection of admin user IDs"
    }
  }
}
